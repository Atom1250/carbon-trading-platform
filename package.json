{
  "name": "@carbon-trading-platform/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=build --all --skip-sync",
    "lint": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=lint --all --skip-sync",
    "test": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=test --all",
    "validate:final": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx reset && NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=test --all && NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run @carbon-trading-platform/carbon-trading-platform-e2e:e2e",
    "test:watch": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=test --all --watch",
    "test:coverage": "NX_DAEMON=false NX_SOCKET_DIR=/tmp/nx-tmp nx run-many --target=test --all --coverage",
    "prepare": "husky",
    "migrate:up": "dotenv -e .env -- node-pg-migrate -m libs/database/migrations --no-check-order up",
    "migrate:down": "dotenv -e .env -- node-pg-migrate -m libs/database/migrations --no-check-order down",
    "migrate:status": "dotenv -e .env -- node-pg-migrate -m libs/database/migrations --no-check-order redo --fake --dry-run",
    "migrate:create": "dotenv -e .env -- node-pg-migrate -m libs/database/migrations create",
    "seed:admin": "dotenv -e .env -- tsx scripts/seed-admin-account.ts",
    "uat:infra:up": "docker compose up -d postgres redis",
    "uat:infra:down": "docker compose down",
    "uat:services": "concurrently -k -n auth,institutions,assets,compliance,trading,ledger,gateway,web -c blue,green,magenta,cyan,yellow,white,red,gray \"PORT=3002 tsx apps/auth-service/src/server.ts\" \"PORT=3003 tsx apps/institution-service/src/server.ts\" \"PORT=3004 tsx apps/asset-service/src/server.ts\" \"PORT=3005 tsx apps/compliance-service/src/server.ts\" \"PORT=3006 tsx apps/trading-service/src/server.ts\" \"PORT=3007 tsx apps/ledger-service/src/server.ts\" \"PORT=3001 AUTH_SERVICE_URL=http://localhost:3002 INSTITUTION_SERVICE_URL=http://localhost:3003 ASSET_SERVICE_URL=http://localhost:3004 COMPLIANCE_SERVICE_URL=http://localhost:3005 TRADING_SERVICE_URL=http://localhost:3006 LEDGER_SERVICE_URL=http://localhost:3007 tsx apps/api-gateway/src/server.ts\" \"cd apps/web-app && NEXT_PUBLIC_API_URL=http://localhost:3001 next dev -p 3000\"",
    "uat:up": "npm run uat:infra:up && npm run migrate:up && npm run seed:admin && npm run uat:services",
    "uat:compose:up": "docker compose up --build -d",
    "uat:compose:logs": "docker compose logs -f",
    "uat:compose:down": "docker compose down",
    "figma:trading:validate": "node scripts/validate-figma-trading-mapping.mjs",
    "figma:landing:validate": "node scripts/validate-figma-landing-mapping.mjs"
  },
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "next": "^14.2.35",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.5.0",
    "@nx/eslint-plugin": "22.5.0",
    "@nx/express": "22.5.0",
    "@nx/jest": "22.5.0",
    "@nx/js": "22.5.0",
    "@nx/next": "^22.5.1",
    "@nx/node": "22.5.0",
    "@nx/web": "22.5.0",
    "@nx/webpack": "22.5.0",
    "@nx/workspace": "22.5.0",
    "@playwright/test": "^1.58.2",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "~0.2.38",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "22.5.0",
    "postcss": "^8.5.6",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
