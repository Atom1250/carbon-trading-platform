# Database
DATABASE_URL=postgresql://platform_user:dev_password@localhost:5432/carbon_trading
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=carbon_trading
DATABASE_USER=platform_user
DATABASE_PASSWORD=dev_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Blockchain
HARDHAT_RPC_URL=http://localhost:8545
